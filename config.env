# Server Monitoring Config

# --- Notification Settings (SMTP) ---
# Use an App Password if using Gmail (2FA enabled)
SMTP_SERVER="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your_email@gmail.com"
SMTP_PASS="your_app_password"
EMAIL_FROM="Monitor <your_email@gmail.com>"
EMAIL_TO="admin@example.com"

# --- Resource Limits ---
# Thresholds in percentage (%)
CPU_ALERT_THRESHOLD=85
RAM_ALERT_THRESHOLD=90
DISK_ALERT_THRESHOLD=90

# --- Disk Configuration ---
# Mount point to check (usually /)
DISK_POINT="/"

# --- Website Monitoring ---
# Format: "URL|REQUIRED_KEYWORD"
# REQUIRED_KEYWORD is optional. If present, the script checks if that text exists on the page.
# If empty, it only validates HTTP 200 status.
WEBSITES=(
    "https://www.google.com|Search"
    "https://www.github.com|"
    "https://expired.badssl.com|" 
)

# --- SSL Certificate ---
# Days before expiration to warn
SSL_WARNING_DAYS=14
